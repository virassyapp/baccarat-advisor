{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/create-checkout-session.js": {
      "maxDuration": 30
    },
    "api/webhook.js": {
      "maxDuration": 30
    }
  },
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/api/create-checkout-session",
      "dest": "/api/create-checkout-session.js",
      "methods": ["POST"]
    },
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js", 
      "methods": ["POST"]
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}